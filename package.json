{
	"name": "code-graph",
	"version": "0.1.0",
	"private": true,
	"description": "Desktop app for manually modeling code graphs.",
	"main": "out/main.js",
	"scripts": {
		"dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:tsc\" \"npm:dev:electron\"",
		"dev:renderer": "vite",
		"dev:electron:tsc": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
		"dev:electron": "wait-on tcp:5173 out/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
		"build": "npm run build:renderer && npm run build:electron",
		"build:renderer": "vite build",
		"build:electron": "tsc -p tsconfig.node.json",
		"preview": "vite preview",
		"start": "npm run build:electron && electron .",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
		"test": "npm run test:component && npm run test:e2e",
		"test:component": "vitest run",
		"test:component:watch": "vitest",
		"test:e2e": "npm run build && playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/react-vite": "^10.3.5",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22.10.6",
		"@types/react": "^18.3.17",
		"@types/react-dom": "^18.3.5",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.2",
		"cross-env": "^7.0.3",
		"electron": "^33.3.1",
		"jsdom": "^29.0.2",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"sass": "^1.99.0",
		"storybook": "^10.3.5",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.7.2",
		"vite": "^6.0.5",
		"vitest": "^4.1.5",
		"wait-on": "^8.0.1"
	}
}
